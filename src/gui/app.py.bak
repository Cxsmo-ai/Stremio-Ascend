    def get_local_ip(self):
        import socket
        try:
            # Connect to a public DNS to find out local IP (doesn't actually connect)
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            ip = s.getsockname()[0]
            s.close()
            return ip
        except:
            return "127.0.0.1"

    def save_settings(self):
        try:
            # Allow selecting "Name (IP)" or just "IP"
            raw_val = self.device_var.get()
            ip = raw_val.split("(")[-1].replace(")", "").strip()
            self.config["adb_host"] = ip
            self.config["tmdb_api_key"] = self.entry_tmdb.get().strip()
            # Discord Client ID hidden/managed internally
            if not self.config.get("discord_client_id"):
                 self.config["discord_client_id"] = "1451010126495617106"
                 
            self.config["trakt_client_id"] = self.entry_trakt_id.get().strip()
            self.config["trakt_client_secret"] = self.entry_trakt_secret.get().strip()
            self.config["show_device_name"] = self.var_show_device.get()
            self.config["profanity_filter"] = self.var_profanity.get()
            # Duplicate line removed here via this replacement block
            self.config["skip_mode"] = self.skip_mode_var.get()
            
            # Legacy Update
            self.config["auto_skip"] = (self.config["skip_mode"] == "auto") 

            # New Settings
            self.config["aniskip_enabled"] = self.var_aniskip.get()
            self.config["aniskip_smart"] = self.var_aniskip_smart.get()
            self.config["mal_client_id"] = self.entry_mal_id.get().strip()
            
            # Update filters
            self.skip_manager.smart_mode = self.config["aniskip_smart"]
            self.skip_manager.enabled = (self.config["skip_mode"] != "off")
            
            # DISCORD HOT-SWAP Removed (ID is internal)
            
            # Update runtime config
            self.controller.host = self.config["adb_host"]
            self.tmdb.api_key = self.config["tmdb_api_key"]
            self.rpc.client_id = self.config["discord_client_id"] # Update RPC too
            
            save_config(self.config)
            print("DEBUG: Settings Saved Successfully")
        except Exception as e:
            print(f"ERROR: Save Failed: {e}")
            from tkinter import messagebox
            messagebox.showerror("Save Error", f"Could not save settings:\n{e}") 

    def start_trakt_auth(self):
        def auth_thread():
            # Update credentials first
            self.save_settings()
            
            # Re-init Trakt with new credentials
            self.trakt = TraktClient(
                client_id=self.config.get("trakt_client_id"),
                client_secret=self.config.get("trakt_client_secret"),
                access_token=self.config.get("trakt_access_token"),
                refresh_token=self.config.get("trakt_refresh_token")
            )
            
            if not self.trakt.client_id:
                 self.btn_trakt_auth.configure(text="Missing Client ID!", fg_color="red")
                 return

            self.btn_trakt_auth.configure(text="Requesting Code...", state="disabled")
            data = self.trakt.get_device_code()
            if not data:
                self.btn_trakt_auth.configure(text="Error connecting", fg_color="red", state="normal")
                return
                
            code = data.get("user_code")
            print(f"Trakt Code: {code}")
            
            # Copy to clipboard
            self.clipboard_clear()
            self.clipboard_append(code)
            
            self.btn_trakt_auth.configure(text=f"Code Copied: {code}", fg_color="#E67E22")
            webbrowser.open(data.get("verification_url"))
            
            # Poll
            res = self.trakt.poll_for_token(data.get("device_code"), data.get("interval", 5))
            if isinstance(res, dict) and "access_token" in res:
                self.config["trakt_access_token"] = res["access_token"]
                self.config["trakt_refresh_token"] = res["refresh_token"]
                self.trakt.set_auth(res["access_token"], res["refresh_token"])
                self.save_settings()
                self.btn_trakt_auth.configure(text="Trakt Connected!", fg_color="#2CC985", state="normal")
            else:
                self.btn_trakt_auth.configure(text="Auth Failed/Expired", fg_color="red", state="normal")

        threading.Thread(target=auth_thread, daemon=True).start()

    def connect_adb(self):
        self.save_settings() # Auto-save on connect
        threading.Thread(target=self._connect_adb_thread, daemon=True).start()

    def _connect_adb_thread(self):
        # Synchronous Call
        self.controller.connect()
        if self.controller.connected:
            self.device_name = self.controller.get_device_name()
            self.lbl_connection.configure(text=f"ADB: {self.device_name}", text_color="#2CC985") # Nice Green
        else:
            self.lbl_connection.configure(text="ADB: Disconnected", text_color="#FF4B4B") # Nice Red

    def scan_network(self):
        self.btn_scan.configure(state="disabled", text="Scanning...")
        threading.Thread(target=self._scan_thread, daemon=True).start()

    async def _scan_async(self):
        # Suppress logging temporarily for smoother scan
        logging.getLogger("stremio-rpc").setLevel(logging.CRITICAL)
        try:
             ips = await ADBDiscovery().scan_network()
        finally:
             logging.getLogger("stremio-rpc").setLevel(logging.DEBUG) # Restore
        return ips

    def scan_for_api(self):
        # Synchronous scan returning list of dicts
        ips = []
        try:
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
            ips = loop.run_until_complete(self._scan_async())
            loop.close()
        except Exception as e:
            print(f"Scan error: {e}")
            ips = []

        results = []
        # Suppress controller logs too
        logging.getLogger("stremio-rpc").setLevel(logging.CRITICAL)
        
        for ip in ips:
            try:
                tmp_ctrl = StremioController(ip, 5555)
                # Attempt quick connect
                if tmp_ctrl.connect():
                    name = tmp_ctrl.get_device_name()
                    results.append({"ip": ip, "name": name})
                    try: tmp_ctrl.device.close()
                    except: pass
                else: 
                     # If connect failed, maybe don't list it? Or list as Unknown?
                     # Listing as Unknown is safer if it's just auth blocked
                     # results.append({"ip": ip, "name": "Unknown"})
                     pass 
            except:
                pass
                
        logging.getLogger("stremio-rpc").setLevel(logging.DEBUG) # Restore
        return results

    def _scan_thread(self):
        devices = self.scan_for_api()
        
        final_list = []
        for d in devices:
            final_list.append(f"{d['name']} ({d['ip']})")
            
        if not final_list: final_list = ["No devices found"]
        
        self.option_device.configure(values=final_list)
        if final_list and "No devices" not in final_list[0]:
            self.device_var.set(final_list[0])
            self.save_settings()
            messagebox.showinfo("Scan", f"Found {len(devices)} devices!")
        else:
            messagebox.showinfo("Scan", "No devices found.")
            
        self.btn_scan.configure(state="normal", text="Scan Network")

    def toggle_monitor(self):
        if self.running:
            self.running = False
            self.btn_toggle_monitor.configure(text="START RPC", fg_color="#8A5CF5")
            self.lbl_rpc.configure(text="RPC: Stopped")
            
            # Clear Discord Status immediately and Disconnect
            if self.rpc:
                try:
                    self.rpc.clear()
                    self.rpc.close() # Fully close
                    print("DEBUG: RPC Closed on Stop")
                except: pass
            
            # FORCE RESET: Create a completely fresh instance
            # This solves the "pypresence loop closed" issue permanently
            self.rpc = DiscordRPC(self.config["discord_client_id"])
            print("DEBUG: DiscordRPC Instance Re-created")
            
            self.last_rpc_payload = {}
            
            # Reset UI
            self.update_poster(None)
            self.lbl_title.configure(text="Ready to Play")
            self.lbl_state.configure(text="RPC Stopped", text_color="#AAAAAA")
            self.progress_bar.set(0)
            
        else:
            self.running = True
            self.btn_toggle_monitor.configure(text="Stop RPC", fg_color="#C0392B") # Dark Red
            self.lbl_rpc.configure(text="RPC: Running")
            threading.Thread(target=self._monitor_loop, daemon=True).start()

    # ... (skipping unchanged methods) ...


    
    def update_poster(self, image: Image.Image):
        if image:
            # Resize for the 200x300 frame
            # TMDB posters are usually 1:1.5 ratio, so this should fit well.
            ctk_img = ctk.CTkImage(light_image=image, dark_image=image, size=(200, 300))
            self.lbl_image.configure(image=ctk_img, text="")
            self.current_poster = ctk_img # Keep reference
        else:
            self.lbl_image.configure(image=None, text="Waiting...")

    def apply_filter(self, text):
        if not text: return text
        # Check toggle (safely get value)
        try:
            if not self.var_profanity.get(): return text
        except: return text

        import re
        # Basic list + specific user request
        bad_words = [
            "fuck", "shit", "bitch", "cunt", "asshole", "dick", "cock", "pussy", 
            "whore", "slut", "bastard", "damn", "fucking", "motherfucker", "cocksman", "nigga", "nigger"
        ]
        # Regex to find words (case insensitive)
        # We use word boundaries \b to avoid clobbering substring matches if desired, 
        # but user said "every letter part of naughty word", usually means whole word masking.
        # "Cocksman" is a whole word.
        pattern = re.compile(r'\b(' + '|'.join([re.escape(w) for w in bad_words]) + r')\b', re.IGNORECASE)
        return pattern.sub(lambda m: '*' * len(m.group()), text)

    def play_pause(self):
        threading.Thread(target=self.controller.play_pause, daemon=True).start()

    def stop_playback(self):
        threading.Thread(target=self.controller.stop, daemon=True).start()

    def next_track(self):
        threading.Thread(target=self.controller.next_track, daemon=True).start()

    def prev_track(self):
        threading.Thread(target=self.controller.prev_track, daemon=True).start()

    def seek_forward(self):
        threading.Thread(target=self.controller.seek_forward, daemon=True).start()

    def seek_backward(self):
        threading.Thread(target=self.controller.seek_backward, daemon=True).start()

    def seek_to(self, target_ms):
        current = self.shared_state.get("position_val", 0)
        threading.Thread(target=self.controller.seek_to, args=(target_ms, int(current)), daemon=True).start()

