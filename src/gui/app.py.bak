    def toggle_skip(self, _=None):
        # Deprecated - handled by save_settings via OptionMenu
        pass

    def _monitor_loop(self):
        # Initialize RPC connection here (IN THIS THREAD) to avoid asyncio threading issues
        # Initialize RPC connection here (IN THIS THREAD) to avoid asyncio threading issues
        if self.config["discord_client_id"] and not self.rpc.connected:
            try:
                self.rpc.connect()
            except: pass # Will retry in loop

        # Update Instances
        if self.tmdb_key != self.config["tmdb_api_key"]:
             self.tmdb_key = self.config["tmdb_api_key"]
             self.tmdb = TMDBClient(self.tmdb_key)
             
        self.mal_client_id = self.config.get("mal_client_id", "")
        self.mal_mapper.client_id = self.mal_client_id
             
        if self.config["discord_client_id"] != self.rpc.client_id:
            # If client ID changed, force RPC re-initialization
            print("DEBUG: Discord Client ID changed. Re-initializing RPC.")
            try:
                self.rpc.close()
            except: pass
            self.rpc = DiscordRPC(self.config["discord_client_id"])
            self.rpc.connected = False # Mark as disconnected to force reconnect below
            
        last_title = None

        # Trakt Scrobble State
        self.last_trakt_playing = False
        self.last_trakt_progress = 0
        self.trakt_scrobbled = False # Reset scrobble status for new item
        
        try:
            while self.running:
                # 1. Ensure Discord RPC Connection
                if self.config["discord_client_id"] and not self.rpc.connected:
                    print("DEBUG: RPC Disconnected. Attempting to connect...")
                    try:
                        self.rpc.connect()
                    except Exception as e:
                        print(f"DEBUG: RPC Connect Retry Failed: {e}")
                        # Don't spam
                        time.sleep(1)

                # 2. Ensure ADB Connection
                if not self.controller.connected:
                    self.controller.connect()
                    if self.controller.connected:
                        self.device_name = self.controller.get_device_name()
                
                if self.controller.connected:
                    status = self.controller.get_playback_status()
                    
                    title = status.get("title")
                    state = status.get("state")
                    position = status.get("position", 0)
                    duration = status.get("duration", 0)
                    search_query = title

                    # 0. Custom Title Overrides (Apply BEFORE GUI update)
                    if title == "MSNBC":
                        title = "MS NOW"        # Output for GUI / RPC
                        search_query = "MSNBC"  # Query for TMDB (to get image)
                    
                    image_url = None
                    display_title = title # Default to raw if not cleaned
                    display_state = state
                    
                    if title and state in ["playing", "paused"]:
                         # Advanced Regex for Scene Releases (e.g. Show.Name.S01E01.1080p...)
                        import re
                        
                        # Controller now extracts season/episode into status["season"] / status["episode"]
                        # We can use that if available, but the regex logic below is also good for cleaning the title.
                        # Let's keep the existing cleaning logic for 'clean_title', but use status S/E for Auto Skip.
                        
                        # 1. Try to find SxxExx pattern (most robust)
                        # Looks for 'S01E01' or 's1e1' preceded by name
                        match = re.search(r'(.*?)[\s\.]*[sS](\d+)[eE](\d+).*', title)
                        
                        # 2. Fallback: Try 1x01 pattern (common in some scrapers)
                        if not match:
                             match = re.search(r'(.*?)[\s\.]*(\d+)x(\d+).*', title)

                        # 3. Fallback: Try "Show Name - 01" (Anime Style) 
                        # This matches "[Group] Show Name - 01 [Info]" -> "Show Name", "01"
                        if not match:
                             match = re.search(r'(.*?)[\s\.]+-[\s\.]+(\d+)(?!\d).*', title)
                             # Note: This blindly assumes it's S01 if not specified, which is common for " - 01"
                             if match:
                                 # We treat "01" as Episode 1, Season 1 (default)
                                 # We need to restructure match group logic below
                                 pass 

                        # 4. Fallback: Try "Show Name 01" (No dash, dangerous but exists)
                        # Excluding years (1999, 20xx)
                        # if not match: ...
                        
                        clean_title = title
                        episode_info = ""
                        season_num = status.get("season") # Prefer parsing from Core if available
                        episode_num = status.get("episode")
                        
                        if match:
                            # Cleanup name: "South.Park" -> "South Park"
                            raw_name = match.group(1).replace(".", " ").strip()
                            
                            # BRACKET CLEANUP: Remove [Group] and (Year) from the captured name
                            # E.g. "[Group] Chainsaw Man" -> "Chainsaw Man"
                            raw_name = re.sub(r'\[.*?\]', '', raw_name)
                            raw_name = re.sub(r'\(.*?\)', '', raw_name)
                            raw_name = raw_name.strip()

                            # If core didn't get it, use this
                            # Check number of groups to decide strategy
                            if len(match.groups()) >= 3:
                                # Strategy 1 & 2: (Name, S, E)
                                if not season_num: season_num = int(match.group(2))
                                if not episode_num: episode_num = int(match.group(3))
                            elif len(match.groups()) == 2:
                                 # Strategy 3: (Name, E) -> Assume S01
                                 if not season_num: season_num = 1
                                 if not episode_num: episode_num = int(match.group(2))
                            
                            clean_title = raw_name
                            episode_info = f"S{season_num:02d}E{episode_num:02d}"
                            
                            # Use clean title for both Display and Search initially
                            search_query = clean_title 
                        else:
                            # Fallback: Just clean up common junk
                            # Remove brackets [] and parenthesis () content completely
                            clean_title = re.sub(r'\[.*?\]', '', title)
                            clean_title = re.sub(r'\(.*?\)', '', clean_title)
                            # Remove file extensions if present
                            clean_title = re.sub(r'\.(mkv|mp4|avi)$', '', clean_title, flags=re.IGNORECASE)
                            clean_title = clean_title.replace(".", " ").strip()
                            search_query = clean_title
                            
                        # Timestamps
                        start_ts = None
                        end_ts = None
                        if state == "playing" and position > 0:
                            start_ts = int(time.time() - (position / 1000))
                            if duration > 0:
                                end_ts = int(start_ts + (duration / 1000)) # INT cast is CRITICAL
                        
                        # FORCE TIMER STOP ON PAUSE (User Request)
                        if state == "paused":
                            start_ts = None
                            end_ts = None

                        imdb_id = None 
                        current_tmdb_id = None # Track ID for skipping

                        if clean_title != getattr(self, "last_clean_title", None):
                             # Reset Trakt scrobble state for new item
                             self.last_trakt_playing = False
                             self.last_trakt_progress = 0
                             self.trakt_scrobbled = False

                        # SMART SEARCH LOGIC
                        if title != getattr(self, "last_raw_user_title", None):
                            
                            # CLEAR CACHES
                            self.cached_ep_details = None
                            
                            q_raw = clean_title
                            q_stripped = re.sub(r'\s*\(?\d{4}\)?.*$', '', clean_title).strip()
                            
                            if q_raw == "MS NOW": q_raw = "MSNBC"; q_stripped = "MSNBC"
                            if search_query and search_query != title: q_raw = search_query; q_stripped = re.sub(r'\s*\(?\d{4}\)?.*$', '', search_query).strip()

                            print(f"DEBUG: Searching TMDB for Raw: '{q_raw}'")
                            meta = self.tmdb.search_content(q_raw)
                            
                            if not meta and q_stripped != q_raw and len(q_stripped) > 2:
                                print(f"DEBUG: Raw search failed. Trying Stripped: '{q_stripped}'")
                                meta = self.tmdb.search_content(q_stripped)
                                if meta:
                                    clean_title = q_stripped

                            image_url = None
                            
                            if meta:
                                # ... (TMDB Success Block - Unchanged) ...
                                print(f"DEBUG: Found Show: {meta.get('title')}")
                                
                                if meta.get("title"):
                                    clean_title = meta.get("title")
                                
                                image_url = meta.get("image_url")
                                imdb_id = meta.get("imdb_id")
                                
                                # Store TMDB ID for Auto Skip
                                current_tmdb_id = meta.get("id")
                                self.current_tmdb_id_cache = current_tmdb_id
                                    
                                if season_num and episode_num:
                                    try:
                                        ep_data = self.tmdb.get_episode_details(meta['id'], season_num, episode_num)
                                        if ep_data and ep_data.get("name"):
                                            ep_name = ep_data.get("name")
                                            episode_info = f"S{season_num:02d}E{episode_num:02d} - {ep_name}"
                                            self.cached_ep_details = (season_num, episode_num, episode_info)
                                            print(f"DEBUG: Found Episode Name: {ep_name}")
                                    except Exception as e:
                                        print(f"DEBUG: Failed to fetch episode info: {e}")
                                
                                img = self.tmdb.download_image(image_url)
                                self.after(0, self.update_poster, img)
                                self.last_image_url = image_url
                                self.current_imdb = imdb_id
                                
                                tmdb_id = meta.get("id")
                                media_type = meta.get("type", "tv")
                                if media_type == "tv":
                                    if season_num and episode_num:
                                         self.current_tmdb_url = f"https://www.themoviedb.org/tv/{tmdb_id}/season/{season_num}/episode/{episode_num}"
                                    else:
                                         self.current_tmdb_url = f"https://www.themoviedb.org/tv/{tmdb_id}"
                                else:
                                    self.current_tmdb_url = f"https://www.themoviedb.org/movie/{tmdb_id}"

                            else:
                                print("DEBUG: TMDB Meta NOT Found. Trying MAL Fallback...")
                                
                                # MAL FALLBACK LOGIC
                                mal_meta_found = False
                                if self.config.get("aniskip_enabled") and self.mal_client_id:
                                    try:
                                        # 1. Resolve MAL ID
                                        mal_id = self.mal_id_cache.get(clean_title)
                                        if not mal_id:
                                             mal_id = self.mal_mapper.search_anime(clean_title)
                                             if mal_id: self.mal_id_cache[clean_title] = mal_id
                                        
                                        # 2. Fetch Details
                                        if mal_id:
                                            mal_details = self.mal_mapper.get_anime_details(mal_id)
                                            if mal_details:
                                                 print(f"DEBUG: Found MAL Meta: {mal_details}")
                                                 clean_title = mal_details.get("title")
                                                 image_url = mal_details.get("image_url")
                                                 self.after(0, self.update_poster, self.tmdb.download_image(image_url)) # Reuse download_image for generic URL
                                                 self.last_image_url = image_url
                                                 
                                                 # Dummy IDs for logic flow
                                                 imdb_id = f"mal_{mal_id}" 
                                                 self.current_imdb = imdb_id
                                                 mal_meta_found = True
                                                 self.current_tmdb_url = f"https://myanimelist.net/anime/{mal_id}"
                                    except Exception as e:
                                        print(f"DEBUG: MAL Fallback Error: {e}")

                                if not mal_meta_found:
                                    print("DEBUG: ALL Meta Checks Failed.")
                                    self.after(0, self.update_poster, None)
                                    self.last_image_url = None
                                    self.current_imdb = None
                                    imdb_id = None
                                    self.current_tmdb_url = "https://www.themoviedb.org/"
                                self.current_tmdb_id_cache = None
                            
                            self.last_clean_title = clean_title
                        else:
                            # Restore cached values for consistent display
                            if getattr(self, "last_clean_title", None):
                                clean_title = self.last_clean_title
                                
                            image_url = getattr(self, "last_image_url", None)
                            imdb_id = getattr(self, "current_imdb", None)
                            current_tmdb_id = getattr(self, "current_tmdb_id_cache", None)

                        # AUTO SKIP LOGIC
                        now = time.time()
                        skip_times = None
                        skip_status_msg = ""
                        skip_status_color = "gray"

                        if imdb_id and season_num and episode_num:
                             # 1. Fetch skip times if needed (Dual Skip Logic)
                             # A. Try IntroDB
                             skip_times = self.skip_manager.get_skip_times(imdb_id, season_num, episode_num)
                             
                             # B. Fallback to Aniskip if enabled and IntroDB failed
                             if not skip_times and self.config.get("aniskip_enabled"):
                                 try:
                                     # Check Cache for MAL ID
                                     mal_id = self.mal_id_cache.get(clean_title)
                                     
                                     # If not cached, resolve it
                                     if not mal_id:
                                          print(f"DEBUG: IntroDB failed. Attempting to resolve MAL ID for '{clean_title}'...")
                                          mal_id = self.mal_mapper.search_anime(clean_title)
                                          if mal_id:
                                              self.mal_id_cache[clean_title] = mal_id
                                              print(f"DEBUG: Resolved MAL ID: {mal_id}")
                                          else:
                                              print("DEBUG: Could not resolve MAL ID.")
                                     
                                     # Query Aniskip
                                     if mal_id:
                                          print(f"DEBUG: Checking Aniskip for MAL {mal_id} Ep {episode_num}...")
                                          # Aniskip returns list of dicts: [{'start':..., 'end':..., 'type':...}]
                                          ani_skips = self.aniskip.get_skip_times(mal_id, episode_num)
                                          if ani_skips:
                                              print(f"DEBUG: Aniskip Found: {ani_skips}")
                                              skip_times = ani_skips
                                 except Exception as e:
                                     print(f"DEBUG: Aniskip Error: {e}")
                             
                             if skip_times:
                                 # Determine types found
                                 types_found = set()
                                 for s in skip_times:
                                     types_found.add(s.get("type", "intro").title())
                                 
                                 skip_status_msg = f"{' & '.join(sorted(types_found))} Skip Found"
                                 skip_status_color = "#2CC985"
                             else:
                                 skip_status_msg = "No Skip Found\nContribute @ introdb.app"
                                 skip_status_color = "#E67E22"
                             
                             # 2. Check position
                             # COOLDOWN: Don't skip if we just skipped in the last 5 seconds
                             # 2. Check position
                             # COOLDOWN: Don't skip if we just skipped in the last 5 seconds
                             if now - getattr(self, "last_skip_time", 0) > 5:
                                 skip_res = self.skip_manager.should_skip(position, skip_times)
                                 
                                 if skip_res:
                                     target_ms, skip_type = skip_res
                                     skip_mode = self.config.get("skip_mode", "auto")
                                     
                                     if skip_mode == "auto":
                                         # AUTO MODE: Execute Immediately
                                         print(f"DEBUG: Auto-Skipping {skip_type} to {target_ms}ms (Source: {imdb_id}) Current: {position}")
                                         self.controller.seek_to(target_ms, current_ms=position)
                                         self.last_skip_time = now
                                         
                                     elif skip_mode == "button":
                                         # BUTTON MODE: Show Button
                                         def do_skip(t=target_ms):
                                              self.controller.seek_to(t, current_ms=position)
                                              self.last_skip_time = time.time()
                                              # Hide button logic happens next loop
                                         
                                         # We use after to safely update UI from thread
                                         self.after(0, lambda: self.btn_skip_action.configure(text=f"SKIP {skip_type.upper()}", command=do_skip))
                                         self.after(0, lambda: self.btn_skip_action.pack(side="left", padx=10))
                                 else:
                                      # Not in skip interval? Hide button
                                      self.after(0, self.btn_skip_action.pack_forget)
                             
                             # Update Shared State for Web UI
                             self.shared_state["skip_status_msg"] = skip_status_msg
                             self.shared_state["skip_status_color"] = skip_status_color

                        # Build Buttons
                        buttons = []
                        tmdb_url = getattr(self, "current_tmdb_url", "https://www.themoviedb.org/")
                        
                        stremio_deep_link = None
                        if imdb_id:
                             # Construct Deep Link
                             # Format: stremio:///detail/{type}/{id}
                             # Or: stremio:///detail/{type}/{id}/{video_id}
                             type_str = "series" if season_num and episode_num else "movie"
                             
                             if type_str == "movie":
                                  stremio_deep_link = f"stremio:///detail/movie/{imdb_id}/{imdb_id}"
                             else:
                                  stremio_deep_link = f"stremio:///detail/series/{imdb_id}/{imdb_id}:{season_num}:{episode_num}"
                        
                        buttons.append({"label": "View on TMDB", "url": tmdb_url})
                        
                        # Add Deep Link Button
                        if stremio_deep_link:
                             buttons.append({"label": "Watch on Stremio", "url": stremio_deep_link})
                        else:
                             buttons.append({"label": "Get Stremio Ascend", "url": "https://github.com/Cxsmo-ai/Stremio-Ascend"})

                        if season_num and episode_num and getattr(self, "cached_ep_details", None):
                             cs, ce, cinfo = self.cached_ep_details
                             if cs == season_num and ce == episode_num:
                                 episode_info = cinfo
    
                        # RPC Update
                        safe_title = self.apply_filter(clean_title)
                        safe_episode = self.apply_filter(episode_info)

                        line1 = safe_title
                        verb = "Watching" if state == "playing" else "Paused"

                        def format_time(ms):
                            if ms <= 0: return "0:00"
                            seconds = int(ms / 1000)
                            m, s = divmod(seconds, 60)
                            h, m = divmod(m, 60)
                            if h > 0: return f"{h}:{m:02d}:{s:02d}"
                            return f"{m}:{s:02d}"

                        device_part = f" on {self.device_name}" if self.var_show_device.get() else ""
                        
                        if safe_episode:
                            line2 = safe_episode
                        else:
                            line2 = f"{verb}{device_part}"
                        
                        small_text_val = f"{verb}{device_part}"

                        current_payload = {
                            "details": line1,
                            "state": line2,
                            "image_url": image_url,
                            "small_image": "play" if state == "playing" else "pause",
                            "small_text": small_text_val,
                            "end_timestamp": end_ts, 
                        }
                        
                        should_update = False
                        force_update = False
                        
                        if self.last_rpc_payload:
                            old_state = self.last_rpc_payload.get("small_image")
                            new_state = "play" if state == "playing" else "pause"
                            
                            if old_state != new_state: force_update = True
                            if line1 != self.last_rpc_payload.get("details"): force_update = True
                                
                            last_ts = self.last_rpc_payload.get("start_ts_val")
                            if start_ts and (not last_ts or abs(start_ts - last_ts) > 5): force_update = True

                        now = time.time()
                        time_since_last = now - getattr(self, "last_update_success_time", 0)
                        
                        if current_payload != self.last_rpc_payload:
                             if force_update or time_since_last >= 15:
                                 should_update = True

                        if should_update:
                            try:
                                if state == "paused":
                                    # User Request: Don't show RPC at all when paused
                                    self.rpc.clear()
                                else:
                                    self.rpc.update(
                                        details=line1,
                                        state=line2,
                                        image_url=image_url,
                                        small_image="play",
                                        small_text=small_text_val,
                                        start_timestamp=start_ts,
                                        end_timestamp=end_ts,
                                        buttons=buttons[:2],
                                        activity_type=3,
                                        party_id=imdb_id if imdb_id else None,
                                        join_secret=stremio_deep_link if stremio_deep_link else None
                                    )
                                
                                self.last_rpc_payload = current_payload
                                self.last_rpc_payload["start_ts_val"] = start_ts
                                self.last_update_success_time = time.time()
                                self.rpc_fail_count = 0 # Reset fail count on success
                            except Exception as e:
                                print(f"DEBUG: RPC Update FAILED: {e}")
                                self.rpc_fail_count = getattr(self, "rpc_fail_count", 0) + 1
                                
                                # If we fail twice in a row, assume connection is dead and force reset
                                if self.rpc_fail_count >= 2:
                                    print("DEBUG: Force Reconnecting RPC due to repeated failures...")
                                    try: self.rpc.close()
                                    except: pass
                                    self.rpc.connected = False # Trigger reconnect in next loop

                        last_title = clean_title + episode_info

                        final_display_title = self.apply_filter(clean_title)
                        safe_ep_info = self.apply_filter(episode_info)
                        base_subtitle = safe_ep_info if safe_ep_info else (state.title() if state else "Idle")
                        
                        if duration and duration > 0:
                             base_subtitle += f" • {format_time(duration)}"
                        
                        final_display_subtitle = base_subtitle

                        self.after(0, lambda t=final_display_title, s=final_display_subtitle, st=state, d=duration, p=position: (
                            self.lbl_title.configure(text=t),
                            self.lbl_state.configure(text=s, text_color="#2CC985" if st=="playing" else "#AAAAAA"),
                            self.progress_bar.set(p / d if d > 0 else 0),
                            self.lbl_skip_msg.configure(text=skip_status_msg, text_color=skip_status_color)
                        ))
                        
                        # Update Safe State for Web Server
                        self.shared_state.update({
                            "title": final_display_title,
                            "subtitle": final_display_subtitle,
                            "progress": position / duration if duration > 0 else 0,
                            "image_url": self.last_image_url,
                            "connected": True,
                            "device": self.device_name,
                            "is_playing": state == "playing",
                            "auto_skip": self.skip_manager.enabled,
                            "position_val": position,
                            "duration_val": duration,
                            # Meta for Submission
                            "meta_imdb": imdb_id,
                            "meta_season": season_num,
                            "meta_episode": episode_num,
                            "skip_status_msg": skip_status_msg,
                            "skip_status_color": skip_status_color
                        })
                        
                        # --- TRAKT SCROBBLE LOGIC ---
                        if self.trakt.access_token and imdb_id:
                            trakt_progress = (position / duration * 100) if duration > 0 else 0
                            
                            # Determine Action
                            trakt_action = None
                            
                            # Only scrobble if changed significantly or state change
                            is_playing = (state == "playing")
                            was_playing = getattr(self, "last_trakt_playing", False)
                            
                            if is_playing and not was_playing:
                                trakt_action = "start"
                            elif not is_playing and was_playing:
                                trakt_action = "pause"
                            elif is_playing and abs(trakt_progress - getattr(self, "last_trakt_progress", 0)) > 5:
                                # Update every 5%
                                trakt_action = "start" # 'start' works as update in Trakt API
                            elif trakt_progress > 90 and not getattr(self, "trakt_scrobbled", False):
                                trakt_action = "stop" # Mark as database watched
                                self.trakt_scrobbled = True
                                
                            if trakt_action:
                                if trakt_action == "stop" and self.trakt_scrobbled and self.last_trakt_progress > 90:
                                     pass # Prevent double stop if already marked as scrobbled
                                else:
                                    print(f"DEBUG: Trakt Scrobble {trakt_action} {trakt_progress}%")
                                    # Need media object
                                    media_obj = {}
                                    if season_num and episode_num:
                                         # For episodes, Trakt expects the show's IMDB ID and episode numbers
                                         media_obj["episode"] = {
                                             "ids": {"imdb": imdb_id}, # This is the show's IMDB ID
                                             "season": season_num,
                                             "number": episode_num
                                         }
                                    else:
                                         media_obj["movie"] = {"ids": {"imdb": imdb_id}}
                                    
                                    if media_obj:
                                         threading.Thread(target=self.trakt.scrobble, args=(trakt_action, media_obj, trakt_progress), daemon=True).start()
                                
                            self.last_trakt_playing = is_playing
                            self.last_trakt_progress = trakt_progress
                        
                    elif state == "stopped":
                         if last_title:
                             self.rpc.clear()
                             self.after(0, self.update_poster, None)
                             last_title = None
    
                time.sleep(self.config["update_interval"])
        except Exception as e:
            print(f"Monitor Loop Critical Error: {e}")
            import traceback
            traceback.print_exc()

    def restart_app(self):
        print("FORCING RESTART...")
        try:
            import subprocess
            # Nuitka/PyInstaller logic: sys.executable is the EXE
            # We don't need sys.argv in a simple restart unless passing flags
            # Using sys.executable directly is the safest for OneFile
            args = [sys.executable]
            
            # If we need to preserve arguments (unlikely for Lite version but good practice)
            # args.extend(sys.argv[1:]) 
            
            subprocess.Popen(args)
            
            # Close the current app
            self.quit()
            self.destroy()
            sys.exit(0)
        except Exception as e:
            print(f"Restart failed: {e}")
            messagebox.showerror("Error", f"Could not restart: {e}")

def run_app():
    try:
        from src.core.logger import setup_logging
        setup_logging()
        app = App()
        app.mainloop()
    except Exception as e:
        import logging
        logging.critical(f'CRITICAL CRASH: {e}', exc_info=True)
        try:
            import tkinter.messagebox
            tkinter.messagebox.showerror('Critical Error', f'Failed to start: {e}')
        except: pass

if __name__ == '__main__':
    run_app()
